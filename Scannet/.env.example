# Supabase — accesibles desde frontend (prefijo VITE_)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase — solo en Vercel Functions, nunca en frontend
SUPABASE_URL=               # mismo valor que VITE_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=

# HuggingFace Inference API — solo en Vercel Functions
HF_API_TOKEN=
HF_MODEL_ID=Lacax/deepseek_ocr_lora

# Mock OCR — devuelve ticket de prueba sin llamar al modelo (true/false)
USE_MOCK_OCR=false

# DeepSeek API — solo en Vercel Functions
DEEPSEEK_API_KEY=
