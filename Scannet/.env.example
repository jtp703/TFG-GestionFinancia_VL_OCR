# Supabase — accesibles desde frontend (prefijo VITE_)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase — solo en Vercel Functions, nunca en frontend
SUPABASE_URL=               # mismo valor que VITE_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=

# OCR.space — extracción de texto de tickets
OCR_SPACE_API_KEY=

# DeepSeek API — parseo a JSON + categorización
DEEPSEEK_API_KEY=

# Mock OCR — devuelve ticket de prueba sin llamar a APIs externas (true/false)
USE_MOCK_OCR=false
VITE_USE_MOCK_OCR=false

# Modelo local (opcional, solo para desarrollo con DeepSeek-OCR-2 en local)
# LOCAL_MODEL_URL=http://localhost:8000

# Tests E2E (Playwright) — usar cuenta de test dedicada, nunca producción
# E2E_TEST_EMAIL=test-e2e@scannet.dev
# E2E_TEST_PASSWORD=TestPassword123!
